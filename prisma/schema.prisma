generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                                                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                               String            @db.VarChar(150)
  email                                              String            @unique @db.VarChar(150)
  passwordHash                                       String            @map("password_hash") @db.VarChar(255)
  houseNumber                                        String?           @unique @map("house_number") @db.VarChar(50)
  address                                            String?
  createdAt                                          DateTime          @default(now()) @map("created_at")
  updatedAt                                          DateTime          @updatedAt @map("updated_at")
  deletedAt                                          DateTime?         @map("deleted_at")
  role                                               UserRole          @default(warga)
  status                                             UserStatus        @default(inactive)
  Expenses_images_Expenses_images_approved_byTousers Expenses_images[] @relation("Expenses_images_approved_byTousers")
  Expenses_images_Expenses_images_created_byTousers  Expenses_images[] @relation("Expenses_images_created_byTousers")
  Income_Income_approved_byTousers                   Income[]          @relation("Income_approved_byTousers")
  Income_Income_created_byTousers                    Income[]          @relation("Income_created_byTousers")
  Reports_Reports_approved_byTousers                 Reports[]         @relation("Reports_approved_byTousers")
  Reports_Reports_created_byTousers                  Reports[]         @relation("Reports_created_byTousers")
  auditLogs                                          AuditLog[]
  bills                                              Bill[]
  expensesApproved                                   Expense[]         @relation("ExpenseApprovedBy")
  expensesRequested                                  Expense[]         @relation("ExpenseRequestedBy")
  feeTypesCreated                                    FeeType[]         @relation("FeeTypeCreatedBy")
  mailerLogs                                         MailerLog[]
  paymentsApproved                                   Payment[]         @relation("PaymentApprovedBy")
  payments                                           Payment[]         @relation("PaymentUser")

  @@map("users")
}

model FeeType {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdBy     String        @map("created_by") @db.Uuid
  name          String        @db.VarChar(150)
  description   String?
  amount        Decimal       @default(0) @db.Decimal(15, 2)
  dueDay        Int?          @map("due_day")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")
  billingPeriod BillingPeriod @default(once) @map("billing_period")
  bills         Bill[]
  creator       User          @relation("FeeTypeCreatedBy", fields: [createdBy], references: [id])

  @@map("fee_types")
}

model Bill {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feeTypeId   String     @map("fee_type_id") @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  billCode    String     @unique @map("bill_code") @db.VarChar(100)
  amount      Decimal    @default(0) @db.Decimal(15, 2)
  periodMonth Int?       @map("period_month")
  periodYear  Int?       @map("period_year")
  dueDate     DateTime   @map("due_date") @db.Date
  paidAt      DateTime?  @map("paid_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")
  status      BillStatus @default(unpaid)
  feeType     FeeType    @relation(fields: [feeTypeId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  payments    Payment[]

  @@unique([feeTypeId, userId, periodMonth, periodYear])
  @@index([userId])
  @@index([feeTypeId])
  @@index([status])
  @@index([dueDate])
  @@index([periodYear, periodMonth])
  @@map("bills")
}

model Payment {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  billId          String         @map("bill_id") @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  amount          Decimal        @default(0) @db.Decimal(15, 2)
  paymentMethod   String?        @map("payment_method") @db.VarChar(100)
  paidAt          DateTime       @map("paid_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  approvedBy      String?        @map("approved_by") @db.Uuid
  deletedAt       DateTime?      @map("deleted_at")
  paymentProofImg String?        @map("payment_proof_img") @db.VarChar(255)
  status          ApprovalStatus @default(pending)
  rejectedReason  String?        @map("rejected_reason") @db.VarChar(255)
  approver        User?          @relation("PaymentApprovedBy", fields: [approvedBy], references: [id])
  bill            Bill           @relation(fields: [billId], references: [id])
  user            User           @relation("PaymentUser", fields: [userId], references: [id])

  @@index([billId])
  @@index([userId])
  @@index([paidAt])
  @@map("payments")
}

model Expense {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestedBy     String            @map("requested_by") @db.Uuid
  approvedBy      String?           @map("approved_by") @db.Uuid
  expenseCode     String            @unique @map("expense_code") @db.VarChar(100)
  title           String            @db.VarChar(200)
  description     String?
  amount          Decimal           @default(0) @db.Decimal(15, 2)
  expenseDate     DateTime          @map("expense_date") @db.Date
  approvedAt      DateTime?         @map("approved_at")
  rejectedReason  String?           @map("rejected_reason") @db.VarChar(255)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")
  status          ApprovalStatus    @default(pending)
  periodMonth     Int?              @map("period_month")
  periodYear      Int?              @map("period_year")
  Expenses_images Expenses_images[]
  approver        User?             @relation("ExpenseApprovedBy", fields: [approvedBy], references: [id])
  requester       User              @relation("ExpenseRequestedBy", fields: [requestedBy], references: [id])

  @@index([requestedBy])
  @@index([approvedBy])
  @@index([status])
  @@index([expenseDate])
  @@map("expenses")
}

model CashTransaction {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  amount          Decimal          @default(0) @db.Decimal(15, 2)
  createdBySystem Boolean          @default(true) @map("created_by_system")
  createdAt       DateTime         @default(now()) @map("created_at")
  deletedAt       DateTime?        @map("deleted_at")
  sourceId        String           @map("source_id") @db.Uuid
  sourceType      String           @map("source_type")
  type            TransactionType?
  periodMonth     Int?             @map("period_month")
  periodYear      Int?             @map("period_year")

  @@map("cash_transactions")
}

model MailerLog {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?              @map("user_id") @db.Uuid
  emailTo       String               @map("email_to") @db.VarChar(150)
  subject       String               @db.VarChar(255)
  body          String
  referenceId   String?              @map("reference_id") @db.Uuid
  sentAt        DateTime?            @map("sent_at")
  errorMessage  String?              @map("error_message")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  deletedAt     DateTime?            @map("deleted_at")
  type          MailerLogType
  referenceType MailerReferenceType? @map("reference_type")
  status        MailerStatus         @default(pending)
  user          User?                @relation(fields: [userId], references: [id])

  @@map("mailer_logs")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  tableName String   @map("table_name") @db.VarChar(100)
  recordId  String?  @map("record_id") @db.Uuid
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Expenses_images {
  id                                       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_by                               String?         @db.Uuid
  approved_by                              String?         @db.Uuid
  expenses_id                              String?         @db.Uuid
  status                                   ApprovalStatus?
  attachment_url                           String?         @db.VarChar(255)
  created_at                               DateTime        @default(now())
  updated_at                               DateTime
  deleted_at                               DateTime?
  users_Expenses_images_approved_byTousers User?           @relation("Expenses_images_approved_byTousers", fields: [approved_by], references: [id])
  users_Expenses_images_created_byTousers  User?           @relation("Expenses_images_created_byTousers", fields: [created_by], references: [id])
  expenses                                 Expense?        @relation(fields: [expenses_id], references: [id])
}

model Income {
  id                              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_by                      String?        @db.Uuid
  income_code                     String         @unique @db.VarChar(100)
  title                           String         @db.VarChar(200)
  description                     String?
  amount                          Decimal        @default(0) @db.Decimal(15, 2)
  income_date                     DateTime       @db.Date
  status                          ApprovalStatus @default(pending)
  approved_at                     DateTime?
  rejected_reason                 String?
  period_month                    Int?
  period_year                     Int?
  created_at                      DateTime       @default(now())
  updated_at                      DateTime
  deleted_at                      DateTime?
  approved_by                     String?        @db.Uuid
  users_Income_approved_byTousers User?          @relation("Income_approved_byTousers", fields: [approved_by], references: [id])
  users_Income_created_byTousers  User?          @relation("Income_created_byTousers", fields: [created_by], references: [id])

  @@index([income_date])
  @@index([status])
}

model Reports {
  id                               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_by                       String?      @db.Uuid
  approved_by                      String?      @db.Uuid
  report_proof_img                 String?      @db.VarChar(255)
  period_month                     Int
  period_year                      Int
  status                           ReportStatus @default(open)
  opening_balance                  Decimal      @default(0) @db.Decimal(15, 2)
  total_income                     Decimal      @default(0) @db.Decimal(15, 2)
  total_expense                    Decimal      @default(0) @db.Decimal(15, 2)
  closing_balance                  Decimal      @default(0) @db.Decimal(15, 2)
  last_calculated_at               DateTime?
  created_at                       DateTime     @default(now())
  updated_at                       DateTime
  deleted_at                       DateTime?
  users_Reports_approved_byTousers User?        @relation("Reports_approved_byTousers", fields: [approved_by], references: [id])
  users_Reports_created_byTousers  User?        @relation("Reports_created_byTousers", fields: [created_by], references: [id])

  @@unique([period_month, period_year])
  @@index([period_year, period_month])
}

enum UserRole {
  superAdmin
  ketuaRT
  bendahara
  warga
}

enum UserStatus {
  active
  inactive
}

enum BillingPeriod {
  monthly
  weekly
  once
}

enum BillStatus {
  unpaid
  pending
  paid
  overdue
  cancelled
}

enum ApprovalStatus {
  approved
  rejected
  pending
}

enum MailerLogType {
  bill_created
  payment_success
  payment_failed
  expense_submitted
  expense_approved
  expense_rejected
  reminder
  system
  registration
  activation
}

enum MailerReferenceType {
  bill
  payment
  expense
  system
  user
}

enum MailerStatus {
  pending
  sent
  failed
}

enum ReportStatus {
  open
  closed
  failed
}

enum TransactionType {
  income
  expenses
}
