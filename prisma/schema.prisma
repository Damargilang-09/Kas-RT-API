// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  superAdmin
  ketuaRT
  bendahara
  warga
}
// "postinstall": "prisma generate"
enum UserStatus {
  active
  inactive
}

enum BillingPeriod {
  monthly
  weekly
  once
}

enum BillStatus {
  unpaid
  pending
  paid
  overdue
  cancelled
}

enum ApprovalStatus {
  approved
  rejected
  pending
}

enum MailerLogType {
  bill_created
  payment_success
  payment_failed
  expense_submitted
  expense_approved
  expense_rejected
  reminder
  system
}

enum MailerReferenceType {
  bill
  payment
  expense
  system
}

enum MailerStatus {
  pending
  sent
  failed
}

enum ExpenseImageType {
  documentation
  prooving
}

enum ReportStatus {
  open
  closed
  failed
}

enum TransactionType {
  income
  expenses
}

// ==========================================
// MODELS
// ==========================================

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String     @db.VarChar(150)
  email        String     @unique @db.VarChar(150)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  role         UserRole   @default(warga)
  houseNumber  String?    @unique @map("house_number") @db.VarChar(50)
  address      String?    @db.Text
  status       UserStatus @default(inactive)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  // Relations
  feeTypesCreated       FeeType[]      @relation("FeeTypeCreatedBy")
  bills                 Bill[]
  payments              Payment[]      @relation("PaymentUser")
  paymentsApproved      Payment[]      @relation("PaymentApprovedBy")
  expensesRequested     Expense[]      @relation("ExpenseRequestedBy")
  expensesApproved      Expense[]      @relation("ExpenseApprovedBy")
  expenseImagesCreated  ExpenseImage[] @relation("ExpenseImageCreatedBy")
  expenseImagesApproved ExpenseImage[] @relation("ExpenseImageApprovedBy")
  incomeCreated         Income[]       @relation("IncomeCreatedBy")
  reportsCreated        Report[]       @relation("ReportCreatedBy")
  reportsApproved       Report[]       @relation("ReportApprovedBy")
  mailerLogs            MailerLog[]
  auditLogs             AuditLog[]

  @@map("users")
}

model FeeType {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdBy     String        @map("created_by") @db.Uuid
  name          String        @db.VarChar(150)
  description   String?       @db.Text
  amount        Decimal       @default(0) @db.Decimal(15, 2)
  billingPeriod BillingPeriod @default(once) @map("billing_period")
  dueDay        Int?          @map("due_day")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  // Relations
  creator User   @relation("FeeTypeCreatedBy", fields: [createdBy], references: [id])
  bills   Bill[]

  @@map("fee_types")
}

model Bill {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feeTypeId   String     @map("fee_type_id") @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  billCode    String     @unique @map("bill_code") @db.VarChar(100)
  amount      Decimal    @default(0) @db.Decimal(15, 2)
  periodMonth Int?       @map("period_month")
  periodYear  Int?       @map("period_year")
  dueDate     DateTime   @map("due_date") @db.Date
  status      BillStatus @default(unpaid)
  paidAt      DateTime?  @map("paid_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  // Relations
  feeType  FeeType   @relation(fields: [feeTypeId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  payments Payment[]

  @@unique([feeTypeId, userId, periodMonth, periodYear])
  @@index([userId])
  @@index([feeTypeId])
  @@index([status])
  @@index([dueDate])
  @@index([periodYear, periodMonth])
  @@map("bills")
}

model Payment {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  billId          String         @map("bill_id") @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  paymentProofImg String?        @map("payment_proof_img") @db.VarChar(255)
  approvedBy      String?        @map("approved_by") @db.Uuid
  amount          Decimal        @default(0) @db.Decimal(15, 2)
  paymentMethod   String?        @map("payment_method") @db.VarChar(100)
  paidAt          DateTime       @map("paid_at")
  status          ApprovalStatus @default(pending)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  // Relations
  bill     Bill  @relation(fields: [billId], references: [id])
  user     User  @relation("PaymentUser", fields: [userId], references: [id])
  approver User? @relation("PaymentApprovedBy", fields: [approvedBy], references: [id])

  @@index([billId])
  @@index([userId])
  @@index([paidAt])
  @@map("payments")
}

model Expense {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestedBy    String         @map("requested_by") @db.Uuid
  approvedBy     String?        @map("approved_by") @db.Uuid
  expenseCode    String         @unique @map("expense_code") @db.VarChar(100)
  title          String         @db.VarChar(200)
  description    String?        @db.Text
  amount         Decimal        @default(0) @db.Decimal(15, 2)
  expenseDate    DateTime       @map("expense_date") @db.Date
  status         ApprovalStatus @default(pending)
  approvedAt     DateTime?      @map("approved_at")
  rejectedReason String?        @map("rejected_reason") @db.Text
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  // Relations
  requester User           @relation("ExpenseRequestedBy", fields: [requestedBy], references: [id])
  approver  User?          @relation("ExpenseApprovedBy", fields: [approvedBy], references: [id])
  images    ExpenseImage[]

  @@index([requestedBy])
  @@index([approvedBy])
  @@index([status])
  @@index([expenseDate])
  @@map("expenses")
}

model ExpenseImage {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdBy     String?           @map("created_by") @db.Uuid
  approvedBy    String?           @map("approved_by") @db.Uuid
  expenseId     String?           @map("expenses_id") @db.Uuid
  name          String?           @db.VarChar(50)
  description   String?           @db.Text
  status        ApprovalStatus?
  type          ExpenseImageType?
  attachmentUrl String?           @map("attachment_url") @db.VarChar(255)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  deletedAt     DateTime?         @map("deleted_at")

  // Relations
  creator  User?    @relation("ExpenseImageCreatedBy", fields: [createdBy], references: [id])
  approver User?    @relation("ExpenseImageApprovedBy", fields: [approvedBy], references: [id])
  expense  Expense? @relation(fields: [expenseId], references: [id])

  @@map("expenses_images")
}

model Income {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdBy      String?        @map("created_by") @db.Uuid
  incomeCode     String         @unique @map("income_code") @db.VarChar(100)
  title          String         @db.VarChar(200)
  description    String?        @db.Text
  amount         Decimal        @default(0) @db.Decimal(15, 2)
  incomeDate     DateTime       @map("income_date") @db.Date
  status         ApprovalStatus @default(pending)
  approvedAt     DateTime?      @map("approved_at")
  rejectedReason String?        @map("rejected_reason") @db.Text
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  // Relations
  creator User? @relation("IncomeCreatedBy", fields: [createdBy], references: [id])

  @@index([status])
  @@index([incomeDate])
  @@map("income")
}

model Report {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdBy        String?      @map("created_by") @db.Uuid
  approvedBy       String?      @map("approved_by") @db.Uuid
  reportProofImg   String?      @map("report_proof_img") @db.VarChar(255)
  periodMonth      Int          @map("period_month")
  periodYear       Int          @map("period_year")
  status           ReportStatus @default(open)
  openingBalance   Decimal      @default(0) @map("opening_balance") @db.Decimal(15, 2)
  totalIncome      Decimal      @default(0) @map("total_income") @db.Decimal(15, 2)
  totalExpense     Decimal      @default(0) @map("total_expense") @db.Decimal(15, 2)
  closingBalance   Decimal      @default(0) @map("closing_balance") @db.Decimal(15, 2)
  lastCalculatedAt DateTime?    @map("last_calculated_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  creator  User? @relation("ReportCreatedBy", fields: [createdBy], references: [id])
  approver User? @relation("ReportApprovedBy", fields: [approvedBy], references: [id])

  @@unique([periodMonth, periodYear])
  @@index([periodYear, periodMonth])
  @@map("reports")
}

// NOTE: source_id bersifat polymorphic — bisa merujuk ke payments, income, atau expenses.
// Prisma tidak support polymorphic relation secara native, sehingga relasi ke tabel sumber
// tidak didefinisikan di sini. Join harus dilakukan manual di service layer
// menggunakan sourceType sebagai penanda tabel ("payment" | "income" | "expense").
model CashTransaction {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionCode String           @unique @map("transaction_code") @db.VarChar(100)
  sourceType      String           @map("source_type")
  sourceId        String           @map("source_id") @db.Uuid
  type            TransactionType?
  amount          Decimal          @default(0) @db.Decimal(15, 2)
  createdBySystem Boolean          @default(true) @map("created_by_system")
  createdAt       DateTime         @default(now()) @map("created_at")
  deletedAt       DateTime?        @map("deleted_at")

  @@map("cash_transactions")
}

model MailerLog {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?              @map("user_id") @db.Uuid
  emailTo       String               @map("email_to") @db.VarChar(150)
  subject       String               @db.VarChar(255)
  body          String               @db.Text
  type          MailerLogType
  referenceType MailerReferenceType? @map("reference_type")
  referenceId   String?              @map("reference_id") @db.Uuid
  status        MailerStatus         @default(pending)
  sentAt        DateTime?            @map("sent_at")
  errorMessage  String?              @map("error_message") @db.Text
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  deletedAt     DateTime?            @map("deleted_at")

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@map("mailer_logs")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  tableName String   @map("table_name") @db.VarChar(100)
  recordId  String?  @map("record_id") @db.Uuid
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
